layout {
    default_tab_template {
        // Bar BEFORE children = renders at the top of the terminal
        pane size=1 borderless=true {
            plugin location="file:~/.config/zellij/plugins/zjstatus/zjstatus.wasm" {

                // ── Catppuccin Mocha colour aliases ────────────────────────────────────
                // Single source of truth. Change a colour here → updates everywhere below.
                // Syntax: color_NAME "hex"  →  reference as $NAME in format strings.
                color_base      "#1e1e2e"
                color_surface0  "#313244"
                color_surface1  "#45475a"
                color_overlay0  "#6c7086"
                color_overlay1  "#7f849c"
                color_overlay2  "#9399b2"
                color_text      "#cdd6f4"
                color_subtext1  "#bac2de"
                color_green     "#a6e3a1"
                color_blue      "#89b4fa"
                color_mauve     "#cba6f7"
                color_peach     "#fab387"
                color_red       "#f38ba8"
                color_yellow    "#f9e2af"
                color_sky       "#89dceb"
                color_sapphire  "#74c7ec"
                color_lavender  "#b4befe"

                // ── Layout zones ───────────────────────────────────────────────────────
                // format_space background = terminal bg → bar is "invisible", pills float.
                // Left:   mode pill  +  session name pill
                // Center: tabs
                // Right:  activity pipes  →  notifications  →  clock
                format_left   "{mode}#[bg=$base] #[fg=$blue,bold]  {session} "
                format_center "{tabs}"
                format_right  "{pipe_zj_activity}#[fg=$overlay1,bg=$base]  {datetime}"
                format_space  "#[bg=$base] "

                border_enabled  "false"
                border_char     "─"
                border_format   "#[fg=$overlay0]{char}"
                border_position "top"

                hide_frame_for_single_pane "false"

                // ── Mode pills ─────────────────────────────────────────────────────────
                // Full-word labels with coloured bg pills — mirrors Sketchybar workspace
                // active-state colour logic. Each mode ends with #[bg=$base] to reset
                // background before the session pill that follows.
                //
                //   normal  → green   (all good, default positive state)
                //   pane    → blue    (navigation focus)
                //   tab     → mauve   (tab management)
                //   resize  → peach   (modification in progress)
                //   move    → yellow  (spatial operation)
                //   scroll  → sky     (read-only navigation)
                //   search  → sky     (read-only navigation)
                //   session → lavender(session management)
                //   tmux    → sapphire(compatibility mode)
                //   locked  → red     (input blocked)
                //   prompt  → overlay1(neutral system prompt)
                mode_normal        "#[bg=$green,fg=$base,bold]  NORMAL  #[bg=$base] "
                mode_locked        "#[bg=$red,fg=$base,bold]  LOCKED  #[bg=$base] "
                mode_pane          "#[bg=$blue,fg=$base,bold]  PANE  #[bg=$base] "
                mode_tab           "#[bg=$mauve,fg=$base,bold]  TAB  #[bg=$base] "
                mode_resize        "#[bg=$peach,fg=$base,bold]  RESIZE  #[bg=$base] "
                mode_move          "#[bg=$yellow,fg=$base,bold]  MOVE  #[bg=$base] "
                mode_scroll        "#[bg=$sky,fg=$base,bold]  SCROLL  #[bg=$base] "
                mode_search        "#[bg=$sky,fg=$base,bold]  SEARCH  #[bg=$base] "
                mode_enter_search  "#[bg=$sky,fg=$base,bold]  SEARCH  #[bg=$base] "
                mode_session       "#[bg=$lavender,fg=$base,bold]  SESSION  #[bg=$base] "
                mode_tmux          "#[bg=$sapphire,fg=$base,bold]  TMUX  #[bg=$base] "
                mode_rename_tab    "#[bg=$mauve,fg=$base,bold]  RENAME  #[bg=$base] "
                mode_rename_pane   "#[bg=$blue,fg=$base,bold]  RENAME  #[bg=$base] "
                mode_prompt        "#[bg=$overlay1,fg=$base,bold]  PROMPT  #[bg=$base] "
                mode_default_to_mode "normal"

                // ── Tabs ───────────────────────────────────────────────────────────────
                // inactive: dim overlay0 text, no bg (blends into the invisible bar)
                // active:   text colour + surface0 bg (subtle elevation — like Sketchybar
                //           bracket bg on a transparent bar, but we need contrast vs base)
                tab_normal              "#[fg=$overlay0,bg=$base] {name} "
                tab_normal_fullscreen   "#[fg=$overlay0,bg=$base] {name} 󰊓 "
                tab_normal_sync         "#[fg=$overlay0,bg=$base] {name}  "
                tab_active              "#[fg=$text,bg=$surface0,bold] {name} "
                tab_active_fullscreen   "#[fg=$text,bg=$surface0,bold] {name} 󰊓 "
                tab_active_sync         "#[fg=$text,bg=$surface0,bold] {name}  "
                tab_separator           "#[fg=$surface0,bg=$base]│"

                // ── Activity indicator ─────────────────────────────────────────────────
                // Single unified pipe for all activity sources (Claude, build, deploy, etc.).
                // Lifecycle is managed entirely by ~/.config/zellij/scripts/notify.sh:
                //   - working states: persistent until overwritten
                //   - success/error:  auto-clears after N seconds (token-based, concurrency-safe)
                //
                // To add a new source: call notify.sh <profile> <status> from any script.
                // Add a [profiles.<name>] entry to notifications.toml for custom messages.
                pipe_zj_activity_format     "#[fg=$text,bg=$base]{output}"
                pipe_zj_activity_rendermode "dynamic"

                // ── Datetime ──────────────────────────────────────────────────────────
                // Passive info, rightmost — same role as Sketchybar clock widget.
                datetime        "{format}"
                datetime_format "%H:%M"
            }
        }
        children
    }
}
